# Copy to vm1.env and edit IPs for your lab.
#   cp vm1.env.example vm1.env

# Your VM1 address (reachable from VM2)
VM1_IP=10.0.0.1

# VM2 address (operator B)
VM2_IP=10.0.0.2

# Path to nexqloud-sealed checkout on this machine
REPO_ROOT=/home/zack/nexqloud/repos/nexqloud-sealed

# Where pid files, logs, and credentials are stored
RUN_DIR=/tmp/nexqloud-destruction-demo-vm1

# Fixed coordinator signing key (64-byte Ed25519 seed hex) for repeatable demos
COORDINATOR_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Tenant used in bootstrap and delete request
TENANT_ID=acme
